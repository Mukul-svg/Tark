# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.

# Required in production (ENV=production), optional in development.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ai_paas?sslmode=disable
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# Server / worker settings
PORT=8080
NAMESPACE=default
WORKER_CONCURRENCY=10

# Set to "production" to enforce required vars and enable fail-fast startup.
ENV=development

# AES-256 key for kubeconfig encryption at rest (64 hex characters = 32 bytes).
# Generate with: openssl rand -hex 32
# Required in production. In development, omit to skip encryption with a warning.
KUBECONFIG_ENCRYPTION_KEY=
